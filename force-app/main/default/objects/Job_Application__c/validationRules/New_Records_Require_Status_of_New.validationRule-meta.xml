<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>New_Records_Require_Status_of_New</fullName>
    <active>true</active>
    <errorConditionFormula>ISNEW() &amp;&amp;  NOT(ISPICKVAL(Status__c, &quot;New&quot;))</errorConditionFormula>
    <errorMessage>When creating a Job Application record, the Status must be equal to &quot;New&quot;</errorMessage>
</ValidationRule>
